# Prefer MYSQL_DATABASE for the real MySQL schema name (especially with hyphens).
# DATABASE_URL can omit the database: ...3306/
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/
MYSQL_DATABASE=pizzashop-api
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=*

# Optional: Redis for cashier menu caching (falls back to in-process TTL if unset).
# REDIS_URL=redis://127.0.0.1:6379/0
# CASHIER_MENU_CACHE_TTL=60
